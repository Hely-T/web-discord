APP_BRAND=Bleck Lous
PUBLIC_DOMAIN=nasdaq-fx.com
HOST=0.0.0.0
PORT=8088
WEB_DB_PATH=/opt/discord-bots/main-bot/database/web-dashboard/web.sqlite3

# Discord OAuth cho nút Login Discord trên web.
# Tạo OAuth2 redirect: https://nasdaq-fx.com/auth/callback
# implicit là mặc định và không cần Client Secret.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://nasdaq-fx.com/auth/callback
DISCORD_OAUTH_MODE=implicit

# Client ID của 2 bot để tạo link invite theo server.
CASINO_BOT_CLIENT_ID=
GENERAL_BOT_CLIENT_ID=
EXTENSION_BOT_CLIENT_ID=
RPC_APPLICATION_ID=
BOT_PERMISSIONS=8

# Optional: nếu muốn Status tự đọc số server đang join trực tiếp từ Discord API,
# cấp token riêng của Bot Tổng/Casino cho web service. Để trống nếu không dùng.
CASINO_BOT_TOKEN=
GENERAL_BOT_TOKEN=

# Optional manual override cho Status. Để trống hoặc 0 = tự dò từ bot runtime/DB/token.
CASINO_SERVER_COUNT=0
GENERAL_SERVER_COUNT=0
EXTENSION_SERVER_COUNT=0

# Admin web quản lý key thuê bot tổng.
ADMIN_PASSWORD=doi_mat_khau_manh
CONTACT_ADMIN_URL=https://discord.com

# Discord voice bot loaded by main.py from archive_bot/cogs.
# Leave DISCORD_TOKEN empty to run only the web dashboard.
DISCORD_TOKEN=
BOT_PREFIX=$
VOICE_STATE_PATH=/opt/bleck-lous-web/archive_bot/data/voice_state.json
VOICE_CONNECT_TIMEOUT=30
VOICE_RECONNECT_BASE_DELAY=15
VOICE_RECONNECT_MAX_DELAY=300

# Bot tong Python
CASH_DB_PATH=/opt/discord-bots/main-bot/database/users.db
BANK_DB_PATH=/opt/discord-bots/main-bot/database/bank_payments.db

# Casino Go
CASINO_DB_PATH=/opt/discord-bots/casino-bot/database/casino.db
